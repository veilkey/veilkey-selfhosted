#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/../.." && pwd)"
installed_bin="/root/veilkey-proxy/bin/veilkey-session-config"
bin_path="${VEILKEY_SESSION_CONFIG_BIN_REAL:-${installed_bin}}"

if [[ ! -x "${bin_path}" ]]; then
  echo "veilkey-session-config binary not found at ${bin_path}" >&2
  exit 1
fi

exec "${bin_path}" --config "${VEILKEY_SESSION_TOOLS_TOML:-/etc/veilkey/session-tools.toml}" "$@"
