[proxy.default]
listen = "127.0.0.1:18080"
url = "http://127.0.0.1:18080"
no_proxy = "127.0.0.1,localhost,.<INTERNAL_DOMAIN>,.<VHOST_DOMAIN>"
plaintext_action = "issue-temp-and-block"
allow_hosts_enabled = false
allow_hosts = []

[proxy.tools.codex]
listen = "127.0.0.1:18080"
url = "http://127.0.0.1:18080"
plaintext_action = "issue-temp-and-block"
plaintext_resolve_hosts = []
allow_hosts_enabled = false
allow_hosts = []

[proxy.tools.claude]
listen = "127.0.0.1:18080"
url = "http://127.0.0.1:18080"
plaintext_action = "issue-temp-and-block"
plaintext_resolve_hosts = []
allow_hosts_enabled = false
allow_hosts = []

[proxy.tools.opencode]
listen = "127.0.0.1:18080"
url = "http://127.0.0.1:18080"
plaintext_action = "issue-temp-and-block"
plaintext_resolve_hosts = []
allow_hosts_enabled = false
allow_hosts = []

[tools.codex]
bin = "/usr/bin/codex"
proxy = "default"

[tools.claude]
bin = "/root/.local/bin/claude"
proxy = "default"

[tools.opencode]
bin = "/root/.opencode/bin/opencode"
proxy = "default"

[veilroot]
default_profile = "codex"
unit_prefix = "veilroot"

[veilkey]
localvault_url = "http://127.0.0.1:10180"
keycenter_url = "http://<HUB_IP>:10180"

# Environment examples:
#   export VEILKEY_LOCALE=ko
#   export VEILKEY_LOCALE=en
